# OpenAI-compatible API settings for benchmark_runner.
# Copy this file to .env and replace the placeholder values.

BENCH_LLM_API_KEY=your_api_key_here
BENCH_LLM_BASE_URL=https://api.openai.com/v1
# Optional: DEBUG, INFO, WARNING, ERROR
# BENCH_LLM_LOG_LEVEL=INFO

#====================================================================
# Optional fallback variable names also supported by benchmark_runner.
# Use them only if you do not want the benchmark-specific BENCH_* names.
#
# LLM_API_KEY => OPENAI_API_KEY => LLM_BASE_URL => OPENAI_BASE_URL=
# LLM_LOG_LEVEL=

# The model name is not read from .env.
# Pass it explicitly on the command line, for example:
# .venv/bin/python -m benchmark_runner run task_80 --model gpt-4o-mini
